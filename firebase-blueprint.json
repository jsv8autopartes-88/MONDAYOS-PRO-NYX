{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user-specific settings and dashboard state.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "theme": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "background": { "type": "string" },
            "cardBg": { "type": "string" }
          }
        },
        "isCarMode": { "type": "boolean" },
        "viewMode": { "type": "string", "enum": ["grid", "list"] },
        "notes": { "type": "string" },
        "aiContext": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Widget": {
      "title": "Widget",
      "description": "A dashboard widget configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "w": { "type": "number" },
        "h": { "type": "number" },
        "code": { "type": "string" },
        "config": { "type": "object" },
        "isVisible": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "title", "type"]
    },
    "AppFile": {
      "title": "AppFile",
      "description": "A file stored in the user's library.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["script", "md", "json", "svg"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name", "type"]
    },
    "RemoteAgent": {
      "title": "RemoteAgent",
      "description": "A remote agent controller (e.g., on Windows local app).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "busy"] },
        "platform": { "type": "string" },
        "lastHeartbeat": { "type": "string", "format": "date-time" },
        "currentTask": { "type": "string" },
        "systemInfo": { "type": "object" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "name", "status", "ownerId"]
    },
    "AgentMission": {
      "title": "AgentMission",
      "description": "A high-level task or goal for one or more agents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "goal": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "paused", "failed"] },
        "subtasks": { "type": "array" },
        "agentId": { "type": "string" },
        "createdAt": { "type": "number" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "title", "goal", "status", "ownerId"]
    },
    "AgentSkill": {
      "title": "AgentSkill",
      "description": "A reusable modular logic snippet for agents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "code": { "type": "string" },
        "category": { "type": "string", "enum": ["system", "automation", "web", "vision"] },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "name", "code", "ownerId"]
    },
    "WebLink": {
      "title": "WebLink",
      "description": "A stored external web link.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "title", "url", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and global settings"
    },
    "/users/{userId}/widgets/{widgetId}": {
      "schema": "Widget",
      "description": "User's dashboard widgets"
    },
    "/users/{userId}/files/{fileId}": {
      "schema": "AppFile",
      "description": "User's library files"
    },
    "/users/{userId}/agents/{agentId}": {
      "schema": "RemoteAgent",
      "description": "Remote agents connected to this account"
    },
    "/users/{userId}/agents/{agentId}/commands/{commandId}": {
      "schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "cmd": { "type": "string" },
          "args": { "type": "array" },
          "status": { "type": "string", "enum": ["pending", "received", "executing", "completed", "failed"] },
          "result": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "completedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Queued commands for the agent"
    },
    "/users/{userId}/missions/{missionId}": {
      "schema": "AgentMission",
      "description": "High-level goal orchestration"
    },
    "/users/{userId}/skills/{skillId}": {
      "schema": "AgentSkill",
      "description": "Modular agent capabilities library"
    },
    "/users/{userId}/links/{linkId}": {
      "schema": "WebLink",
      "description": "User's favorite web links"
    },
    "/users/{userId}/reports/{reportId}": {
      "schema": "AppFile",
      "description": "System generated audit reports"
    }
  }
}
